{
    "name": "luizfelipeoliver/laravel-crud-kit",
    "type": "library",
    "description": "CRUD generator for Laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "Luiz Oliveira",
            "email": "luizfelipeoliver@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Example\\LaravelCrudKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Example\\LaravelCrudKit\\KrakenServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
